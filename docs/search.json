---
---
[
  {% assign docs = site.data.research_library %}
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: "%B %d, %Y" | jsonify }},
      "excerpt": {{ post.excerpt | strip_html | strip_newlines | truncatewords: 20 | jsonify }}
    }{% unless forloop.last and docs.size == 0 %},{% endunless %}
  {% endfor %}
  {% for doc in docs %}
    {% assign keywords = doc.tags | join: ", " %}
    {
      "title": {{ doc.title | jsonify }},
      "url": {{ '/library/#' | append: doc.id | relative_url | jsonify }},
      "date": {{ doc.year | jsonify }},
      "excerpt": {{ doc.abstract | append: " " | append: keywords | truncatewords: 28 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
